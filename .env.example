# --- CMS admin password (gates all CMS writes) ---
CMS_ADMIN_TOKEN=change-me-formax-cms

# --- Storage (Vercel Blob) ---
# Add a Blob store to your Vercel project and this is set automatically.
# When present, CMS content + leads persist to Blob; otherwise the local
# data/ JSON files are used (development) or per-instance memory (fallback).
BLOB_READ_WRITE_TOKEN=
# Optional overrides:
# CMS_CONTENT_BLOB_PATH=cms/site-content.json
# CMS_SUBMISSIONS_BLOB_PREFIX=cms/leads

# --- Cloudinary image uploads (optional; paste image URLs if unset) ---
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=formax/cms

# --- Local dev server ---
HOST=127.0.0.1
PORT=8000
